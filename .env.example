# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ─── Claude / Anthropic ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ─── Google My Business ───────────────────────────────────────────────────────
GOOGLE_MY_BUSINESS_CLIENT_ID=your-client-id
GOOGLE_MY_BUSINESS_CLIENT_SECRET=your-client-secret
GOOGLE_MY_BUSINESS_REDIRECT_URI=https://app.dikho.in/api/auth/google/callback

# ─── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@dikho.in

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxxxxxxxxxxx@oN.ingest.sentry.io/xxxxxxxx
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── App config ───────────────────────────────────────────────────────────────
ROOT_DOMAIN=dikho.in
NEXT_PUBLIC_APP_URL=https://app.dikho.in
NODE_ENV=development
